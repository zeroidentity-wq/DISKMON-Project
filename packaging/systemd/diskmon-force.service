[Unit]
Description=Diskmon daily/on-demand storage report (one-shot)
After=network.target

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=/etc/diskmon
ExecStart=/usr/local/bin/diskmon-mail/diskmon-mail --force-mail
StandardOutput=journal
StandardError=journal
Nice=10
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
